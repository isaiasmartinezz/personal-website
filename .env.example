# Copy this file to `.env.local` and fill in as needed. `.env.local` is
# gitignored. On Vercel/Netlify, set these in the dashboard instead.

# --- Contact form email delivery (optional) -------------------------------
# Only needed if you enable the Resend block in src/app/api/contact/route.ts.
# Get a key at https://resend.com
RESEND_API_KEY=

# --- Site URL (optional) --------------------------------------------------
# The canonical URL is read from src/data/site.ts (`url`). You generally edit
# it there rather than here.
